# SMTP configuration for /api/contact (server-only, do NOT prefix with NEXT_PUBLIC_)
SMTP_HOST=mail.techmodulus.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contact@techmodulus.com
SMTP_PASSWORD=your-smtp-password-here

# Optional overrides (default to SMTP_USER)
MAIL_TO=contact@techmodulus.com
MAIL_FROM=TechModulus Website <contact@techmodulus.com>
