# CloudLinux Node.js Selector manages the Passenger block automatically.
# Do not store secrets in this file. Configure env vars in the cPanel UI.
# If Node.js Selector writes its own Passenger section here, keep that block.

Options -Indexes

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-Frame-Options "SAMEORIGIN"
</IfModule>

<FilesMatch "^\.">
  Require all denied
</FilesMatch>
